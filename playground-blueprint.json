{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/marketing/",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "phpExtensionBundles": ["kitchen-sink"],
  "steps": [
    {
      "step": "login",
      "username": "admin",
      "password": "password"
    },
    {
      "step": "setSiteOptions",
      "options": {
        "permalink_structure": "/%postname%/",
        "blogname": "ATP Marketing Preview",
        "blogdescription": "America Tracking Polls — marketing site (Playground preview)"
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "vibe-ai"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "git:directory",
        "url": "https://github.com/mirror-factory/ATP-Demo",
        "ref": "refs/heads/atp-website",
        "path": "."
      },
      "options": {
        "activate": true
      }
    }
  ]
}
